host = {
  name           = "omni"
  cores          = 4
  memory         = 4096
  ip_addr        = "10.0.69.30"
  gateway        = "10.0.69.1"
  cidr           = "/24"
  node_name      = "proxmox"
  network_bridge = "vmbr0"
  vlan_id        = 69
  datastore_id   = "ssd"
  disk_size      = 64
}

proxmox = {
  url                   = "https://10.0.3.10:8006/"
  download_node_name    = "proxmox"
  download_datastore_id = "local"
  host_description      = "Managed by OpenTofu"
  host_tags             = ["tofu", "omni"]
}

# Sensitive – copy to terraform.auto.tfvars and keep out of version control
omni = {
  endpoint       = "omni.example.com"
  auth_endpoint  = "omni.example.com"
  admin_email    = "admin@example.com"
  admin_password = "changeme"
  omni_version   = "v1.7.0"   # pin to a specific release; set "" to always use latest
  public_ip      = "1.2.3.4"
}
